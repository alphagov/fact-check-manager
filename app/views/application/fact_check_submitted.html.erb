<% content_for :page_title, t("fact_check_submitted.fact_check_submitted") %>
<% content_for :title_context, t("fact_check_submitted.fact_check_submitted") %>
<div class="govuk-grid-row">
  <div
    class="govuk-grid-column-two-thirds"
    data-module="ga4-links-setup ga4-link-tracker"
  >
      <%= render "govuk_publishing_components/components/panel", {
        title: t("fact_check_submitted.fact_check_submitted"),
        heading_level: 1,
        description: t("fact_check_submitted.fact_check_description"),
      } %>
      <p class="govuk-body"> <%= t("fact_check_submitted.sent_a_confirmation_email") %> </p>
      <%= render "govuk_publishing_components/components/heading", {
          text: t("fact_check_submitted.what_happens_next"),
          margin_bottom: 6,
      } %>
      <%= render @response.accepted? ? "application/partials/accepted_next_steps" : "application/partials/rejected_next_steps" %>
      <p class="govuk-body"><%= link_to t("fact_check_submitted.what_do_you_think"),
          "https://www.gov.uk/done/fact-check-manager",
          class: "govuk-link",
          target: "_blank",
          rel: "noopener" %>
          <%= t("fact_check_submitted.thirty_sec") %></p>
  </div>
</div>
