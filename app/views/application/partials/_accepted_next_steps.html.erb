<% if @request.zendesk_number.present? %>
  <p class="govuk-body">
    <%= t("fact_check_submitted.contact_you_with_zendesk_link_html", zendesk_link: zendesk_ticket_link(@request)) %>
  </p>
<% else %>
  <p class="govuk-body">
    <%= t("fact_check_submitted.contact_you") %>
  </p>
<% end %>

<%= render "govuk_publishing_components/components/list", {
  visible_counters: true,
  items: [
    t("fact_check_submitted.when_changes"),
    t("fact_check_submitted.when_questions"),
  ]}
%>
