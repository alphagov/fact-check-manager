<% environment = GovukPublishingComponents::AppHelpers::Environment.current_acceptance_environment %>

<%# data_module_main = ga4_form_tracking? ? "ga4-link-tracker ga4-form-setup ga4-index-section-setup" : "ga4-link-tracker" %>

<% content_for :head do %>
  <meta name="govuk:components_gem_version" content="<%= GovukPublishingComponents::VERSION %>">
  <%= javascript_include_tag "es6-components", type: "module" %>
<% end %>

<% sanitized_title = sanitize((yield(:page_title).presence || yield(:title))) %>

<%= render "govuk_publishing_components/components/layout_for_admin", {
  product_title: "Fact Check Manager",
  browser_title: yield(:page_title),
  environment: environment,
  head: yield(:head),
} do %>
  
  <%= render "govuk_publishing_components/components/skip_link" %>

  <%= render "govuk_publishing_components/components/layout_header", {
    product_name: "Fact Check Manager",
    environment: environment,
    navigation_items: [],
  } %>

  <div class="govuk-width-container">
    <% if content_for?(:back_link) %>
      <%= render "govuk_publishing_components/components/back_link", { href: yield(:back_link) } %>
    <% end %>
    <main
      id="main-content"
      class="govuk-main-wrapper govuk-main-wrapper--auto-spacing"
      role="main"
    >
      <%#= render "shared/flash", flash: flash %>
      <% if content_for?(:error_summary) %>
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-two-thirds">
            <%= yield(:error_summary) %>
          </div>
        </div>
      <% end %>

      <% if yield(:title).present? %>
        <div class="govuk-grid-row">
          <div class="govuk-grid-column-two-thirds">
            <%= render "govuk_publishing_components/components/heading", {
              text: yield(:title),
              context: yield(:title_context),
              margin_bottom: 6,
              font_size: "xl",
              heading_level: 1,
            } %>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </div>

  <%= render "govuk_publishing_components/components/layout_footer", {
    navigation: [],
  } %>
<% end %>
